<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AEEAFA"
    tools:context=".examenResistencia.ExamenActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calcular Valor de resistencias"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="#CDDC39"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/ivTabla"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="fitCenter"
            android:src="@drawable/tabla"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Spinner
                android:id="@+id/spBanda1"
                android:layout_width="160dp"
                android:layout_height="35dp"
                android:background="#D3D3D3"/>
            <TextView
                android:id="@+id/tvBanda1"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:text="-"
                android:gravity="center"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">
            <Spinner
                android:id="@+id/spBanda2"
                android:layout_width="160dp"
                android:layout_height="35dp"
                android:background="#D3D3D3"/>
            <TextView
                android:id="@+id/tvBanda2"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:text="-"
                android:gravity="center"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <Spinner
                android:id="@+id/spMultiplicador"
                android:layout_width="160dp"
                android:layout_height="35dp"
                android:background="#D3D3D3"/>
            <TextView
                android:id="@+id/tvMultiplicador"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:text="-"
                android:gravity="center"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tolerancia"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <RadioGroup
                    android:id="@+id/rgTolerancia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <RadioButton
                        android:id="@+id/rbOro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="oro"
                        android:checked="true"/>
                    <RadioButton
                        android:id="@+id/rbPlata"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="plata"/>
                </RadioGroup>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTolerancia"
                android:layout_width="80dp"
                android:layout_height="30dp"
                android:background="#FFC107"
                android:textColor="#000000"
                android:gravity="center"
                android:textStyle="bold"
                android:text="5%"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="calcular"
            android:backgroundTint="#CDDC39"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_gravity="center">

            <TextView
                android:text="valor ohm"
                android:textStyle="bold"
                android:layout_marginEnd="24dp"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvResultadoOhm"
                android:text="0"
                android:textSize="16sp"/>

            <TextView
                android:text="valor maximo"
                android:textStyle="bold"
                android:layout_marginEnd="24dp"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvResultadoMaximo"
                android:text="0"
                android:textSize="16sp"/>

            <TextView
                android:text="valor minimo"
                android:textStyle="bold"
                android:layout_marginEnd="24dp"
                android:textSize="16sp"/>
            <TextView
                android:id="@+id/tvResultadoMinimo"
                android:text="0"
                android:textSize="16sp"/>
        </GridLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>